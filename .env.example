# Django/FastAPI
SECRET_KEY=change-me-in-production
DEBUG=true

# Database
POSTGRES_USER=wizly
POSTGRES_PASSWORD=wizly
POSTGRES_DB=wizly
DATABASE_URL=postgresql+asyncpg://wizly:wizly@postgres:5432/wizly

# JWT
JWT_SECRET_KEY=change-me-in-production-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=10080

# OpenAI
LITELLM_API_KEY=sk-...

# Embeddings
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ChromaDB
CHROMA_PERSIST_DIR=/app/chroma

# File uploads
UPLOAD_DIR=/app/uploads

# CORS — comma-separated allowed origins (set to your domain in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# LangSmith tracing (optional — https://smith.langchain.com)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=wizly-ai-twin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
