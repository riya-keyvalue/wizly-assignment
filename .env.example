# Django/FastAPI
SECRET_KEY=change-me-in-production
DEBUG=true

# Database
POSTGRES_USER=wizly
POSTGRES_PASSWORD=wizly
POSTGRES_DB=wizly
# Hostname localhost: use when the API and Alembic run on your machine and Postgres is on port 5432 (e.g. docker compose).
# Use hostname postgres when the app runs inside Docker Compose on the same network as the db service.
DATABASE_URL=postgresql+asyncpg://wizly:wizly@localhost:5432/wizly
# Optional: only if DATABASE_URL uses @postgres: and you run `alembic` on the host:
# ALEMBIC_DATABASE_URL=postgresql+asyncpg://wizly:wizly@localhost:5432/wizly

# JWT
JWT_SECRET_KEY=change-me-in-production-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=10080

# OpenAI
LITELLM_API_KEY=sk-...

# Embeddings
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768
# Semantic chunking (Chonkie SemanticChunker; same model as EMBEDDING_MODEL)
CHUNK_SIMILARITY_THRESHOLD=0.75
CHUNK_MAX_TOKENS=512
# Set true in tests/CI to avoid loading the embedder twice at import/startup
# SKIP_CHUNKER_WARMUP=false

# Qdrant (Docker Compose service: http://qdrant:6333 inside stack, http://localhost:6333 on host)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# File uploads
UPLOAD_DIR=/app/uploads

# CORS — comma-separated allowed origins (include both localhost and 127.0.0.1 if you use either)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# LangSmith tracing (optional — https://smith.langchain.com)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=wizly-ai-twin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
